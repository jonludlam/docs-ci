opam-version: "2.0"
synopsis: "OCaml package build and documentation system"
maintainer: [
  "Navin Keswani <navin@novemberkilo.io>"
  "Tim McGilchrist <timmcgil@gmail.com>"
]
authors: ["lucas@tarides.com"]
license: "MIT"
homepage: "https://github.com/ocurrent/ocaml-docs-ci"
bug-reports: "https://github.com/ocurrent/ocaml-docs-ci/issues"
depends: [
  "dune" {>= "3.20"}
  "ocaml" {>= "5.1"}
  "opam-format" {>= "2.1.4"}
  "opam-0install" {>= "0.4.3"}
  "yojson"
  "bos"
  "fpath"
  "rresult"
  "astring" {>= "0.8.5"}
  "cmdliner" {>= "1.1.0"}
  "dockerfile" {>= "8.2.1"}
  "fmt" {>= "0.8.9"}
  "logs" {>= "0.7.0"}
  "lwt" {>= "5.6.1"}
  "eio"
  "eio_main"
  "git-unix" {>= "3.13.0"}
  "ppx_deriving_yojson" {>= "3.7.0"}
  "alcotest" {>= "1.7.0" & with-test}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/ocurrent/ocaml-docs-ci.git"
x-maintenance-intent: ["(latest)"]
